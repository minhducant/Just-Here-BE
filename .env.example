# Application
NODE_ENV=development
APP_NAME=just-here-be
APP_PORT=3000
APP_PREFIX=api
APP_URL=http://localhost:3000
VERSION=1.0.0

# JWT - Client
CLIENT_JWT_ACCESS_TOKEN_SECRET=your_client_access_token_secret
CLIENT_JWT_ACCESS_TOKEN_EXPIRATION_TIME=3600
CLIENT_JWT_REFRESH_TOKEN_SECRET=your_client_refresh_token_secret
CLIENT_JWT_REFRESH_TOKEN_EXPIRATION_TIME=604800

# JWT - User
USER_JWT_ACCESS_TOKEN_SECRET=your_user_access_token_secret
USER_JWT_ACCESS_TOKEN_EXPIRATION_TIME=3600
USER_JWT_REFRESH_TOKEN_SECRET=your_user_refresh_token_secret
USER_JWT_REFRESH_TOKEN_EXPIRATION_TIME=604800

# MongoDB
MONGO_URI=mongodb://localhost:27017/just-here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# Sentry
SENTRY_DNS=https://your-sentry-dsn@sentry.io/project-id

# MailService (Nodemailer SMTP)
# Set MAIL_ENABLE=true to activate email sending
MAIL_ENABLE=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ACCOUNT=your_smtp_user@example.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM="Just-Here <no-reply@example.com>"
# MAIL_SERVICE is optional — use a well-known service name (e.g. gmail, outlook)
# instead of MAIL_HOST/MAIL_PORT when connecting to popular providers.
MAIL_SERVICE=

# Linode Object Storage
LINODE_UPLOAD_PATH=uploads
LINODE_ACCESS_KEY_ID=your_linode_access_key
LINODE_SECRET_ACCESS_KEY=your_linode_secret_key
LINODE_BUCKET_NAME=your-bucket-name
LINODE_REGION=ap-south
LINODE_DOMAIN=your-bucket-domain
LINODE_BASE_URL=https://your-bucket.ap-south-1.linodeobjects.com
UPLOAD_LIMIT=10485760

# OAuth Providers
FACEBOOK_GRAPH_API=https://graph.facebook.com
ZALO_BASE_API=https://openapi.zalo.me
GOOGLE_BASE_API=https://www.googleapis.com
APPLE_JWKS=https://appleid.apple.com/auth/keys
APPLE_ISSUER=https://appleid.apple.com

# Stripe
API_KEY=your_stripe_secret_key
SUCCESS_URL=http://localhost:3000/success
CANCEL_URL=http://localhost:3000/cancel

# Server
WEB_URL=http://localhost:3001

# Token expiration
CLIENT_SIGN_UP_EXPIRATION_TIME=86400
CLIENT_FORGOT_PASSWORD_EXPIRATION_TIME=3600
